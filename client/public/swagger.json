{
  "openapi": "3.0.0",
  "info": {
    "title": "灵犀AI API",
    "version": "1.0.0",
    "description": "灵犀AI平台完整API文档"
  },
  "servers": [
    {"url": "http://localhost:5001", "description": "Flask后端服务"},
    {"url": "http://localhost:9080", "description": "CMDB后端服务"},
    {"url": "http://localhost:5002", "description": "AI Graph服务"}
  ],
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": ["认证管理"],
        "summary": "用户注册",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {"type": "string"},
                  "password": {"type": "string"}
                },
                "required": ["username", "password"]
              }
            }
          }
        },
        "responses": {"200": {"description": "注册成功"}}
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["认证管理"],
        "summary": "用户登录",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {"type": "string"},
                  "password": {"type": "string"}
                },
                "required": ["username", "password"]
              }
            }
          }
        },
        "responses": {"200": {"description": "返回token"}}
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": ["认证管理"],
        "summary": "获取当前用户信息",
        "responses": {"200": {"description": "用户信息"}}
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["认证管理"],
        "summary": "用户登出",
        "responses": {"200": {"description": "登出成功"}}
      }
    },
    "/api/models": {
      "get": {
        "tags": ["模型配置"],
        "summary": "获取模型列表",
        "parameters": [
          {"name": "page", "in": "query", "schema": {"type": "integer", "default": 1}},
          {"name": "per_page", "in": "query", "schema": {"type": "integer", "default": 10}},
          {"name": "keyword", "in": "query", "schema": {"type": "string"}},
          {"name": "filters", "in": "query", "schema": {"type": "string"}, "description": "JSON格式过滤条件"}
        ],
        "responses": {"200": {"description": "模型分页列表"}}
      },
      "post": {
        "tags": ["模型配置"],
        "summary": "创建模型",
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object"}}}},
        "responses": {"201": {"description": "创建成功"}}
      }
    },
    "/api/models/{id}": {
      "get": {
        "tags": ["模型配置"],
        "summary": "获取模型详情",
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "模型详情"}}
      },
      "put": {
        "tags": ["模型配置"],
        "summary": "更新模型",
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object"}}}},
        "responses": {"200": {"description": "更新成功"}}
      },
      "delete": {
        "tags": ["模型配置"],
        "summary": "删除模型",
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "删除成功"}}
      }
    },
    "/api/model-instances": {
      "get": {
        "tags": ["模型数据"],
        "summary": "获取模型实例列表（支持搜索、分页、过滤）",
        "parameters": [
          {"name": "keyword", "in": "query", "schema": {"type": "string"}},
          {"name": "page", "in": "query", "schema": {"type": "integer", "default": 1}},
          {"name": "per_page", "in": "query", "schema": {"type": "integer", "default": 20}},
          {"name": "filters", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "模型实例分页列表"}}
