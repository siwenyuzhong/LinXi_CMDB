      "post": {
        "tags": ["模型数据"],
        "summary": "批量删除模型实例",
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "properties": {"ids": {"type": "array", "items": {"type": "integer"}}}}}}},
        "responses": {"200": {"description": "批量删除成功"}}
      }
    },
    "/api/model-instances/meta/models": {
      "get": {
        "tags": ["模型数据"],
        "summary": "获取模型实例元数据模型列表",
        "parameters": [{"name": "per_page", "in": "query", "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "模型列表"}}
      }
    },
    "/api/model-instances/meta/relation-options": {
      "get": {
        "tags": ["模型数据"],
        "summary": "获取关联关系选项",
        "parameters": [{"name": "model_definition_id", "in": "query", "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "关联关系选项"}}
      }
    },
    "/api/workflows": {
